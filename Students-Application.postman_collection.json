{
  "info": {
    "_postman_id": "a1e4c9d0-2b7f-4e6a-9c3d-students-app-collection",
    "name": "Students Application",
    "description": "CRUD API for the Students Application, secured with Keycloak (OAuth2 Resource Server, Bearer JWT). Import together with the 'Students Application - Local' environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{access_token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth (Keycloak)",
      "item": [
        {
          "name": "Get Token - Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{client_id}}", "type": "text" },
                { "key": "client_secret", "value": "{{client_secret}}", "type": "text" },
                { "key": "username", "value": "{{admin_username}}", "type": "text" },
                { "key": "password", "value": "{{admin_password}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
            },
            "description": "Obtains an access token for a user with ROLE_ADMIN. Saves it into {{access_token}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test(\"Response has access_token\", function () {",
                  "    pm.expect(body.access_token).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.environment.set(\"access_token\", body.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Token - Non-Admin User",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{client_id}}", "type": "text" },
                { "key": "client_secret", "value": "{{client_secret}}", "type": "text" },
                { "key": "username", "value": "{{user_username}}", "type": "text" },
                { "key": "password", "value": "{{user_password}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
            },
            "description": "Obtains an access token for a user with only ROLE_USER. Saves it into {{access_token_user}}, used by the 403 checks below."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.environment.set(\"access_token_user\", body.access_token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Students - Happy Path",
      "item": [
        {
          "name": "Get All Students",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/students",
              "host": ["{{base_url}}"],
              "path": ["students"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response is an array\", function () {",
                  "    pm.expect(pm.response.json()).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ali\",\n  \"lastName\": \"Valiyev\",\n  \"age\": \"20\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/students",
              "host": ["{{base_url}}"],
              "path": ["students"]
            },
            "description": "Requires ROLE_ADMIN. Saves the created student's id into {{student_id}} for later requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test(\"Response has generated id\", function () {",
                  "    pm.expect(body.id).to.be.a(\"number\");",
                  "});",
                  "",
                  "pm.environment.set(\"student_id\", body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Student By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/students/id?id={{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["students", "id"],
              "query": [
                { "key": "id", "value": "{{student_id}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Sardor\",\n  \"lastName\": \"Valiyev\",\n  \"age\": \"22\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/students/{{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["students", "{{student_id}}"]
            },
            "description": "Requires ROLE_ADMIN."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Fields were updated\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.firstName).to.eql(\"Sardor\");",
                  "    pm.expect(body.age).to.eql(\"22\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Student",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/students?id={{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["students"],
              "query": [
                { "key": "id", "value": "{{student_id}}" }
              ]
            },
            "description": "Requires ROLE_ADMIN."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 204\", function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Students - Security & Validation",
      "item": [
        {
          "name": "Get All Students - No Token (expect 401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/students",
              "host": ["{{base_url}}"],
              "path": ["students"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Student - ROLE_USER (expect 403)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{access_token_user}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ali\",\n  \"lastName\": \"Valiyev\",\n  \"age\": \"20\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/students",
              "host": ["{{base_url}}"],
              "path": ["students"]
            },
            "description": "Run 'Get Token - Non-Admin User' first. A user without ROLE_ADMIN must be rejected."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 403\", function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Student - Blank firstName (expect 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"\",\n  \"lastName\": \"Valiyev\",\n  \"age\": \"20\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/students",
              "host": ["{{base_url}}"],
              "path": ["students"]
            },
            "description": "@NotBlank validation on StudentRequestDTO.firstName must reject this."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Student By Id - Not Found (expect 404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/students/id?id=999999",
              "host": ["{{base_url}}"],
              "path": ["students", "id"],
              "query": [
                { "key": "id", "value": "999999" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 404\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}