<?xml version="1.0" encoding="UTF-8"?>
<!--
    Project-local Maven settings for Students Application.
    Overrides the machine-wide ~/.m2/settings.xml (which mirrors central to an
    unreachable corporate Nexus) so this project always resolves from Maven Central.
    Referenced automatically via .mvn/maven.config.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.1.0 http://maven.apache.org/xsd/settings-1.1.0.xsd">
</settings>